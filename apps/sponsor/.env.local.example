# Sponsor app — Base Sepolia (testnet). See README for context.
#
# Most contract addresses below have defaults baked into
# @skillos/contracts/src/addresses.ts; override here only when
# pointing to a different network or a forked/local deployment.

# ─── Network ──────────────────────────────────────────────────────────────
# Base Sepolia chain (84532).
NEXT_PUBLIC_CHAIN_ID=84532

# Optional Base Sepolia RPC override (defaults to https://sepolia.base.org).
BASE_SEPOLIA_RPC_URL=

# ─── Contract addresses (Base Sepolia) ────────────────────────────────────
# Verified on Blockscout: https://base-sepolia.blockscout.com/
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_TOURNAMENT_POOL_V21_ADDRESS=0x52049b812780134d2F69D6c20C2ef881D49702da
NEXT_PUBLIC_SPONSORSHIP_MODULE_ADDRESS=0xD76670adB574A4C8D06dfF47127e7143d780ff87
NEXT_PUBLIC_SPONSOR_RECEIPT_SBT_ADDRESS=0xCCC183c72D666A16E03bf38E8c2DFa8a68b2e768
NEXT_PUBLIC_SANCTIONS_ORACLE_ADDRESS=0x0CB38F0A0511aF07FC34A20DCaB9e2Fc8061B1CC

# ─── Supabase ──────────────────────────────────────────────────────────────
# Public URL + anon key power read paths from the browser.
# Service-role key is server-only (cron writes sponsor_events).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Vercel cron auth ──────────────────────────────────────────────────────
# Shared secret. Vercel attaches `Authorization: Bearer ${CRON_SECRET}` to
# scheduled cron requests. /api/cron/index-sponsor-events compares against
# this value. Generate with `openssl rand -hex 32`. If unset in production
# the route returns 401 on every cron fire (auth check fails closed). Local
# dev tolerates an unset value (auth bypassed when NODE_ENV !== "production").
CRON_SECRET=

# ─── Sponsor indexer ───────────────────────────────────────────────────────
# Block height at which SponsorshipModule was deployed on Base Sepolia.
# Sponsor cron (packages/duel-backend/src/cron/sponsors.ts) starts indexing
# SponsorPool events from this block on first run. Default in code:
# 40_851_426 (deploy block of 0xD76670adB574A4C8D06dfF47127e7143d780ff87).
# Override here only if the contract is redeployed.
SPONSOR_INDEXER_DEPLOY_BLOCK=40851426

# Skillbase Orchestrator — dedicated cron host (Base Sepolia testnet).
#
# This app exposes ONLY /api/cron/* routes. No UI, no public surface.
# Cron triggers are project-bound in Vercel (no domain alias required).
# All four handlers gate on the shared CRON_SECRET below.
#
# Required env vars are split into:
#   - Required (no default): app refuses or fails-loud if unset
#   - Required-with-defaults: source has a fallback in @skillos/contracts
#                              or @skillos/lib-shared
#
# After Phase 2 mainnet migration, NEXT_PUBLIC_CHAIN_ID + every NEXT_PUBLIC_*_ADDRESS
# rotates to mainnet equivalents. See @skillos/contracts/src/addresses.ts.

# ─── Required (no default) ─────────────────────────────────────────────────
# Vercel attaches `Authorization: Bearer ${CRON_SECRET}` to every scheduled
# fire. Generate with `openssl rand -hex 32`. If unset in production every
# cron returns 401 (auth fails closed).
CRON_SECRET=

# Studio signer — signs settle()/walkover() and anchorSnapshot() txs. Server-only.
# Must match ChallengeEscrow.trustedSigner AND be in SkillbaseAnchor.authorizedAnchors.
STUDIO_PRIVATE_KEY=

# Supabase — service-role key is required for cron writes. The anonymous
# anon key is intentionally NOT in this app (cron paths never use it).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SkillbaseAnchor — required by /api/cron/anchor-sp-snapshot. Empty default in
# code; cron returns 500 if unset (fail-loud is correct for an op-critical addr).
NEXT_PUBLIC_SKILLBASE_ANCHOR_ADDRESS=0x9d033b3A9aD12955222169b21c8cD487D84064CA

# ─── Required-with-defaults ────────────────────────────────────────────────
# Override these only when pointing to a different network or fork.

# Base Sepolia chain (84532). Default in @skillos/contracts.
NEXT_PUBLIC_CHAIN_ID=84532

# Base Sepolia RPC. Default falls back to https://sepolia.base.org (rate-limited
# public endpoint). Provide a private RPC URL in production for predictable QPS.
BASE_SEPOLIA_RPC_URL=

# Contract addresses — defaults in @skillos/contracts/src/addresses.ts. Set
# these explicitly to pin against env-dashboard drift.
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_TOURNAMENT_POOL_V2_ADDRESS=0x52049b812780134d2F69D6c20C2ef881D49702da
NEXT_PUBLIC_TOURNAMENT_POOL_V21_ADDRESS=0x52049b812780134d2F69D6c20C2ef881D49702da
NEXT_PUBLIC_SPONSORSHIP_MODULE_ADDRESS=0xD76670adB574A4C8D06dfF47127e7143d780ff87
NEXT_PUBLIC_SPONSOR_RECEIPT_SBT_ADDRESS=0xCCC183c72D666A16E03bf38E8c2DFa8a68b2e768
NEXT_PUBLIC_SANCTIONS_ORACLE_ADDRESS=0x0CB38F0A0511aF07FC34A20DCaB9e2Fc8061B1CC

# Sponsor indexer — block height to start from on first run. Default in code:
# 40_851_426 (SponsorshipModule deploy block, 2026-04-29).
SPONSOR_INDEXER_DEPLOY_BLOCK=40851426

# Tournament create — default prize pool USDC amount (6 decimals) seeded into
# new daily/weekly tournaments. Read by packages/duel-backend/src/cron/tournaments.ts.
TESTNET_DEFAULT_PRIZE_POOL=

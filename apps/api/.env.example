# ─── Discipline preamble (read before adding values) ────────────────────
#
# Pattern #19 — Env paste ≠ env wired. After `vercel env add <KEY>
# production`, VERIFY with `vercel env ls production | grep <KEY>`. The grep
# output (showing `Encrypted` + `Production` columns) is the canonical proof
# the value landed. A returned shell prompt is NOT proof — terminal scrollback
# can hide a paste truncation or an unconfirmed `^C` at the prompt step.
#
# Pattern #20 — Generated secret save discipline. Private keys printed by
# `cast wallet new` / `openssl rand` / similar are stdout-ephemeral. Save in
# the SAME code block that generates: Foundry keystore (`cast wallet import`),
# password manager, or `gpg --symmetric` to disk. Never rely on terminal
# scrollback. Testnet outcome of losing a key = orphan wallet; mainnet outcome
# = real-value loss.
#
# See `.claude/memory/feedback_patterns.md` for the full pattern catalogue.

# ─── X1 read-path env ────────────────────────────────────────────────────

# Read-path RPC for Base Sepolia (used by publicClient — /v1/tournaments,
# /v1/scores/:wallet, /v1/sponsors/:wallet/receipts). Defaults to the public
# endpoint, which has a permissive 10k-block eth_getLogs range — required
# by our chunked event scanner. Override ONLY if you have a premium RPC
# whose eth_getLogs range is at least 10k.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Write-path RPC (used by walletClient — /v1/scores submit). Falls back to
# BASE_SEPOLIA_RPC_URL if unset. Set this to Alchemy/QuickNode/etc. for
# write-path reliability without affecting reads — premium RPCs typically
# have superior uptime on eth_sendRawTransaction even when their getLogs
# tier is too tight for our scanner.
BASE_SEPOLIA_WRITE_RPC_URL=

# TournamentPool v2.1 deploy block (Base Sepolia, 2026-04-29).
# Used as fromBlock for eth_getLogs scans. Without this, scans run from
# 'earliest' and are very slow on cold cache.
SPONSOR_INDEXER_DEPLOY_BLOCK=

# Optional override for /v1/health version field.
API_VERSION=

# ─── X2 write-path env (NEW) ─────────────────────────────────────────────

# 32+ random bytes (hex or base64), used to sign + verify HS256 bearer JWTs.
# Rotate independently per environment (testnet vs mainnet); rotation
# invalidates all outstanding bearers immediately. Never reuse across envs.
JWT_SECRET=

# Supabase project URL + service role key. SERVICE_ROLE_KEY bypasses RLS;
# treat as a high-trust secret.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Trusted signer private key for TournamentPool submitSoloScore attestations.
# MUST correspond to the trustedSigner address set on the deployed
# TournamentPool v2.1 (0xA24f9122568e98b72f4dDD61119C7D92D0975692 on testnet).
# Mismatch = on-chain revert with BadSignature. NEVER log or echo this value.
#
# X15 deprecation path: STUDIO_PRIVATE_KEY's responsibility is narrowing to
# submitSoloScore attestation only. The chargeRetryFee broadcaster role was
# split out to AGENT_PRIVATE_KEY in X15.3 (see ADR 0003 D1). The X20 marathon
# era of "studio masquerades as the agent" is closed. Phase 2 mainnet rotation
# procedure for STUDIO_PRIVATE_KEY follows the X19b key-rotation playbook;
# Phase 2 expansion to also rotate AGENT_PRIVATE_KEY is queued in X19b.1.
STUDIO_PRIVATE_KEY=

# SIWE domain for /v1/auth/siwb/verify. Defaults to "skillos.network" if unset.
# Override for local dev (e.g., "localhost") if testing wagmi sample frontends.
SIWE_DOMAIN=skillos.network

# ─── X4 SIWA agent auth env (NEW) ────────────────────────────────────────

# HMAC secret for SIWA receipt issuance + verification (@buildersgarden/siwa).
# Separate from JWT_SECRET — receipts are issued by /v1/auth/siwa/verify and
# carried in the X-SIWA-Receipt header on subsequent agent requests. Same
# rotation policy as JWT_SECRET: never reuse across envs; rotation invalidates
# outstanding receipts (agents re-sign with SIWA). 32+ random chars.
SIWA_RECEIPT_SECRET=

# ERC-8004 AgentIdentity registry address. Required for SIWA's ownerOf() check
# during /v1/auth/siwa/verify. Base Sepolia: 0x8004A818BFB912233c491871b3d84c89A494BD9e
# (same eip1967 proxy implementation as mainnet 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432).
# Both verified ERC-721 contracts; both tagged "8004 Identity Registry" on Blockscout.
ERC8004_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ─── X5 x402 paywalled data tier env (NEW) ───────────────────────────────

# Receiver wallet for x402 USDC payments. MUST be a fresh testnet address
# with zero on-chain history — no role overlap with trustedSigner, sponsor,
# deployer, or agent test wallets (wallet hygiene rule). Production value
# set in Vercel only; this placeholder is intentionally a burn address so
# any payment to a misconfigured environment is provably unrecoverable.
X402_RECEIVER_ADDRESS=0x000000000000000000000000000000000000dEaD

# x402 facilitator URL. Testnet default: https://x402.org/facilitator
# (no signup, supports Base Sepolia + Solana Devnet). Mainnet swap:
# https://api.cdp.coinbase.com/platform/v2/x402 (CDP, 1k tx/month free,
# requires API key on settle endpoint — Phase 2 wiring).
X402_FACILITATOR_URL=https://x402.org/facilitator

# ─── X15 agent x402 retry payments env (NEW) ─────────────────────────────

# Private key for the agent wallet that BOTH (a) signs EIP-3009 authorizations
# for x402 settlement (apps/api/src/lib/x402-client.ts) AND (b) broadcasts the
# on-chain chargeRetryFee tx whose msg.sender must equal `player`
# (apps/api/src/lib/duel/charge-retry-fee.ts). The agent address is exposed in
# duel_runs.agent_address and in the spectator UI.
#
# Wallet hygiene (Pattern #20): generate fresh per environment. Save to a
# Foundry keystore or password manager IMMEDIATELY at generation time. Test-
# net key loss = orphan funds + identity rotation; mainnet key loss = real-
# value incident requiring role-rotation per ADR 0003 X19b.1 follow-up.
#
# Pattern #18 reminder: prior to X15.6 this key was tolerated as missing on
# the free-first-slot solo flow (priorSolo == 0 skipped chargeRetryFee).
# X15.6 made getAgentAccount() unconditional in reserveSoloRun, so the key
# is now required for ANY solo POST. Verify with `vercel env ls production`
# before redeploys (Pattern #19).
AGENT_PRIVATE_KEY=

# ─── X20 marathon (Anthropic-driven agent loop) env ──────────────────────

# Anthropic API key for the Haiku 4.5 + Sonnet 4.6 calls in apps/api/src/lib/
# duel/anthropic-{agent,client}.ts. Spectator-visible reasoning per move is
# generated here. Per-move latency budget ~1.5s; loop bails at 55s wall-clock
# or 24 moves (whichever first). Phase 2 may swap to Anthropic Managed Agents
# for the inner loop — env name preserved across that transition.
ANTHROPIC_API_KEY=

# Demo tournament for X20 + X15.6 production path. UNSET → dev mode: x402 +
# chargeRetryFee + submitSoloScore all skip (local-dev + first-deploy
# functional). SET (bytes32 hex 0x…) → full production chain runs per ADR 0003
# D5 orchestration order: priorSolo read → x15_payment_attempts insert →
# settleX402Payment → chargeRetryFee/skip → runSoloMatch → submitSoloScore.
#
# Verification: `cast call <TOURNAMENT_POOL_V21_ADDRESS> "tournaments(bytes32)"
# <id> --rpc-url https://sepolia.base.org` should return a row with non-zero
# fields and sponsorWallet matching the expected sponsor address.
X20_DEMO_TOURNAMENT_ID=

# Apex marketing site watch URL base. Used in the 202 response's watchUrl
# field returned by POST /v1/agents/matches/start-solo. Default points at the
# production apex domain; override for local dev / preview testing.
APEX_WATCH_BASE_URL=https://skillos.network/watch

# ─── Cron + admin paths (verified per existing routes) ───────────────────

# Shared secret for /api/cron/* endpoints. The cron caller (Vercel Cron, or a
# local poll script) sends it as the `Authorization: Bearer <secret>` header;
# routes refuse to write tournament state without a match. Memory: the cron
# is the ONLY writer of tournament state outside ops break-glass paths.
CRON_SECRET=

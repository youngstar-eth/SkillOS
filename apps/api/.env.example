# Public RPC for Base Sepolia. Override only if rate-limited on default.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# TournamentPool v2.1 deploy block (Base Sepolia, 2026-04-29).
# Used as fromBlock for eth_getLogs scans. Without this, scans run from
# 'earliest' and are very slow on cold cache.
SPONSOR_INDEXER_DEPLOY_BLOCK=

# Optional override for /v1/health version field.
API_VERSION=

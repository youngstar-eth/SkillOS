{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install",
  "buildCommand": "echo 'no build step — TypeScript bundled by @vercel/node'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 10,
      "includeFiles": "../../node_modules/{hono,viem,abitype,@noble,@scure,@adraffy,ws,isows,ox,eventemitter3,@hono/zod-validator,openapi3-ts}/**"
    }
  }
}

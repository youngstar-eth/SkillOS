# Base Sepolia chain (84532)
NEXT_PUBLIC_CHAIN_ID=84532

# Deployed contracts (Base Sepolia)
NEXT_PUBLIC_CHALLENGE_ESCROW_ADDRESS=0x52e5E45456DeC882048b430a968Cda6061575be0
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Studio signer — signs settle() + walkover() calls. Server-only,
# never exposed to client. Must match ChallengeEscrow.trustedSigner.
STUDIO_PRIVATE_KEY=
# Optional Base Sepolia RPC override (defaults to https://sepolia.base.org).
BASE_SEPOLIA_RPC_URL=

# x402 — Base Sepolia via CDP facilitator (testnet)
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_NETWORK=eip155:84532
X402_PAY_TO=0xA24f9122568e98b72f4dDD61119C7D92D0975692
CDP_API_KEY_ID=<from portal.cdp.coinbase.com>
CDP_API_KEY_SECRET=<from portal.cdp.coinbase.com>

# Test wallet for smoke script only — never commit actual key
X402_TEST_WALLET_PRIVATE_KEY=0x<funded with Base Sepolia USDC + ETH>

# CDP Paymaster — sponsors ETH gas for Smart Wallet users (EIP-5792).
# Server-only; proxied via /api/paymaster, never exposed to client.
# Get URL from portal.cdp.coinbase.com → project → Onchain Tools → Paymaster → Configuration.
# Allowlist (configured in CDP portal): TournamentPool v2 chargeRetryFee + USDC approve.
# Per-user $0.50/day, global $50/day & $1000/month.
CDP_PAYMASTER_URL=<from portal.cdp.coinbase.com>

# Mainnet config (future migration — post-submission)
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# X402_NETWORK=eip155:8453
# X402_PAY_TO=<dedicated treasury TBD>

# Deployer EOA — funds Base Sepolia gas and owns the contract.
DEPLOYER_PRIVATE_KEY=0x...

# Base Sepolia USDC (official)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Address derived from STUDIO_PRIVATE_KEY (set in apps/*/.env.local).
# MUST match the address STUDIO_PRIVATE_KEY actually derives to, otherwise
# submitScore / submitSoloScore will revert with BadSignature on-chain.
#
# How to verify locally before deploy:
#   node -e "const {privateKeyToAccount} = require('viem/accounts'); \
#            console.log(privateKeyToAccount(process.env.STUDIO_PRIVATE_KEY).address)"
# → must equal this value.
#
# If this env ever drifts post-deploy, fix on-chain via:
#   SCORE_SIGNER_ADDRESS=<correct-addr> TOURNAMENT_POOL_V2_ADDRESS=<pool> \
#     forge script script/SetTournamentPoolSigner.s.sol \
#     --rpc-url base_sepolia --broadcast
SCORE_SIGNER_ADDRESS=0x...

# Recipient of protocolFeeBps (default 10%) on tournament settlement.
FEE_RECIPIENT=0x...

# Basescan verification key
BASESCAN_API_KEY=

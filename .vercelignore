# Exclude from Vercel deploy upload.
# node_modules / .next are already ignored by Vercel default.

# Solidity artifacts (not needed for frontend builds)
contracts/out/
contracts/cache/
contracts/broadcast/

# Game design specs at repo root (not used at runtime).
# Leading slash anchors to root so it won't match nested prompts/ dirs
# (e.g. packages/mas-shared/src/ai/prompts/ which IS needed at build time).
/prompts/

# Ad-hoc scripts
/scripts/

# Worktree artifacts
.claude/worktrees/

# Misc
*.log
.DS_Store

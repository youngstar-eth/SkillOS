{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.local.example"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "STUDIO_PRIVATE_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "CRON_SECRET",
        "SPONSOR_INDEXER_DEPLOY_BLOCK",
        "TESTNET_DEFAULT_PRIZE_POOL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}

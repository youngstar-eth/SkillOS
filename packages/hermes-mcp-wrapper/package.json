{
  "name": "@skillos/hermes-mcp-wrapper",
  "version": "0.1.0",
  "private": true,
  "description": "Thin TypeScript wrapper exposing Nous Research Hermes 3 (via OpenRouter) behind a wire-identical MCP client surface, so multi-agent demos can swap Hermes in alongside Claude over the same @modelcontextprotocol/sdk transport.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/wrapper.test.ts",
    "test:integration": "tsx --test tests/integration.smoke.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "openai": "^4.77.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

{
  "name": "@skillos/mcp",
  "version": "0.1.0",
  "description": "Official Model Context Protocol server for SkillOS — list tournaments, submit scores, fund pools, register agents, and fetch x402-paywalled tier data from any MCP-compatible client (Claude Desktop, Cursor, agent runtimes).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://docs.skillos.network",
  "repository": {
    "type": "git",
    "url": "https://github.com/youngstar-eth/skillos.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "skillos",
    "mcp",
    "model-context-protocol",
    "claude-desktop",
    "x402",
    "base",
    "agent",
    "ai-agent",
    "tournament"
  ],
  "bin": {
    "skillos-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http --port 3030",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@buildersgarden/siwa": "0.0.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@skillos/sdk": "^0.2.1",
    "@x402/axios": "^2.11.0",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "axios": "^1.15.0",
    "viem": "^2.48.1",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

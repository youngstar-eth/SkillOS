# npm 7+ enforces peerDependency resolution strictly, but `peerOptional`
# chains can falsely fail. Sprint X4 added @buildersgarden/siwa@0.0.24,
# which declares optional peers on @openfort/openfort-node, which in turn
# declares optional peers on @solana/transaction-confirmation. npm tries
# to resolve the whole chain even though we don't install Openfort.
#
# `legacy-peer-deps=true` matches the npm 6 behavior — install peers
# best-effort, don't fail on optional-peer conflicts. Safe here because
# every conflicting layer is peerOptional, not a strict peer.
#
# CI inherits this via npm ci.
legacy-peer-deps=true
